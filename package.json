{
  "name": "zbot2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:web": "npm --workspace @zbot2/web run dev",
    "start": "bun src/index.ts",
    "start:web": "npm --workspace @zbot2/web run start",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "discord.js": "^14.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.2"
  }
}
